NODE_ENV=development
PORT=3000

# Must match docker-compose.yml. Default user/password are fine for local dev.
DATABASE_URL=postgres://canopy:canopy@localhost:5432/canopy

# Must be at least 32 chars. Generate with: openssl rand -base64 48
JWT_SECRET=replace-me-with-a-long-random-string-at-least-32-chars-aaaa
JWT_EXPIRES_IN=7d

BCRYPT_ROUNDS=10

# Platform (admin) account seeded by `npm run seed`. Admins are provisioned,
# not self-registered. Change these before seeding anything real.
ADMIN_EMAIL=admin@canopy.example
ADMIN_PASSWORD=admin12345
ADMIN_NAME=Canopy Admin
